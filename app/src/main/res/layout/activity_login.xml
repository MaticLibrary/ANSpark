<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Logowanie"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Wejdz do ANSpark i otworz feed dopasowan."
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/inputEmailLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_input"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <EditText
            android:id="@+id/inputPasswordLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Haslo"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/accent_yellow"
            android:text="Logowanie"
            android:textAllCaps="false"
            android:textColor="@color/text_dark"
            android:textSize="17sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGoRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/accent_blue"
            android:text="Nowe konto"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenFeed"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/card_bg"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            android:text="Pokaz aplikacje: Otworz feed"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</ScrollView>
