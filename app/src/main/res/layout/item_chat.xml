<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/itemChatAvatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_circle_avatar"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/female_profile_1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemChatName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maja, 24"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemChatMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jutro po 18:00 mam wolne, pasuje Ci?"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/itemChatTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="09:12"
        android:textColor="@color/text_hint"
        android:textSize="12sp" />
</LinearLayout>
