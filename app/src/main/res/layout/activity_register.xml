<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nowe konto"
            android:textColor="@color/text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Podstawowe dane profilu. Potem uzupelnisz bio i avatar."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Krok 1 z 2"
            android:textColor="@color/accent_yellow"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:hint="Imie wyswietlane"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <EditText
            android:id="@+id/inputBirthDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:cursorVisible="false"
            android:focusable="false"
            android:hint="Data urodzenia"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Plec"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/radioGenderFemale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/accent_yellow"
                android:text="Kobieta"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/radioGenderMale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/accent_yellow"
                android:text="Mezczyzna"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Szukam"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupPreference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/radioPreferenceWomen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/accent_yellow"
                android:text="Kobiety"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/radioPreferenceMen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/accent_yellow"
                android:text="Mezczyzni"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <EditText
            android:id="@+id/inputPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Haslo"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <EditText
            android:id="@+id/inputCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="Miasto"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNextStep"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/accent_yellow"
            android:text="Dalej"
            android:textAllCaps="false"
            android:textColor="@color/text_dark"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGoLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/card_bg"
            android:text="Masz juz konto? Logowanie"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp" />
    </LinearLayout>
</ScrollView>
